{
  "name": "guess-the-tweeter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "bun scripts/dev.js",
    "dev:client": "bunx --bun vite",
    "server": "bun server/index.js",
    "start": "NODE_ENV=production bun server/index.js",
    "generate:posts": "bun scripts/generate-posts.js",
    "archive:estimate-ai": "bun scripts/generate-ai-archive.js --estimate",
    "archive:generate-ai": "bun scripts/generate-ai-archive.js",
    "archive:generate": "bun scripts/pregenerate-archive.js",
    "archive:schedule": "bun scripts/schedule-rounds.js",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview"
  },
  "dependencies": {
    "@tsrx/react": "0.1.5",
    "@tanstack/react-router": "1.121.21",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@tsrx/vite-plugin-react": "0.0.13",
    "@vitejs/plugin-react": "6.0.1",
    "vite": "8.0.10"
  }
}
